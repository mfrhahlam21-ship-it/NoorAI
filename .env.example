# GEMINI_API_KEY: Required for Gemini AI API calls to enable live crash analysis and game tuning.
# Get your key from: https://ai.google.dev/
# If empty, the server falls back to smart local simulator.
# Example: GEMINI_API_KEY="your-actual-api-key-here"
GEMINI_API_KEY=

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
